{
  "name": "session-bandit",
  "version": "0.1.5",
  "description": "Search, browse, and extract information from your coding agent sessions (Claude Code, Codex).",
  "license": "MIT",
  "author": "Jan Ole Suhr",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "session-bandit": "./dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "cli",
    "coding-agent",
    "claude-code",
    "codex",
    "session",
    "transcript",
    "handoff",
    "memory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/janole/session-bandit.git"
  },
  "homepage": "https://github.com/janole/session-bandit",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm -r build",
    "prepack": "pnpm -r build"
  },
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@session-bandit/core": "workspace:*"
  }
}
